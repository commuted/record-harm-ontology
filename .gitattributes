# Auto detect text files and perform LF normalization
* text=auto

# RDF/Turtle files
*.ttl text eol=lf
*.rdf text eol=lf
*.owl text eol=lf
*.n3 text eol=lf
*.nt text eol=lf
*.nq text eol=lf
*.trig text eol=lf

# Markdown and documentation
*.md text eol=lf
*.txt text eol=lf

# Python
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# SPARQL queries
*.sparql text eol=lf
*.rq text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
